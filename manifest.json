{
  "manifest_version": 3,
  "name": "Jayden Multilingual Translator",
  "version": "1.0.5",
  "description": "Real-time dual-language subtitles for web audio and video.",
  "permissions": [
    "tabCapture",
    "storage",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icon16.png",
      "48": "assets/icon48.png",
      "128": "icon.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["overlay.css", "assets/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
